{
  "name": "@prismedia/web-svelte",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "node scripts/copy-jassub-assets.mjs",
    "dev": "vite dev --port 5173 --host",
    "prebuild": "node scripts/copy-jassub-assets.mjs",
    "build": "vite build",
    "preview": "vite preview --port 5173",
    "start": "node build/index.js",
    "sync": "svelte-kit sync",
    "lint": "svelte-check --tsconfig ./tsconfig.json",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json",
    "api:generate": "orval --config orval.config.ts && node scripts/gen-codes.mjs",
    "api:generate:codes": "node scripts/gen-codes.mjs",
    "test": "pnpm test:unit",
    "test:unit": "vitest run --config vitest.config.ts",
    "api:check": "node scripts/check-generated.mjs"
  },
  "dependencies": {
    "@fontsource/cinzel": "^5.2.8",
    "@pierre/trees": "1.0.0-beta.4",
    "@prismedia/contracts": "workspace:*",
    "@prismedia/media-core": "workspace:*",
    "@prismedia/ui-svelte": "workspace:*",
    "@tiptap/core": "^3.23.6",
    "@tiptap/extension-link": "^3.23.6",
    "@tiptap/extension-placeholder": "^3.23.6",
    "@tiptap/pm": "^3.23.6",
    "@tiptap/starter-kit": "^3.23.6",
    "hls.js": "^1.6.16",
    "jassub": "2.4.2",
    "marked": "^18.0.4",
    "pdfjs-dist": "^6.0.227",
    "svelte-dnd-action": "^0.9.69",
    "tiptap-markdown": "^0.9.0",
    "vidstack": "^1.12.13"
  },
  "devDependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource/geist-sans": "^5.2.5",
    "@lucide/svelte": "^1.16.0",
    "@sveltejs/adapter-static": "3.0.10",
    "@sveltejs/kit": "^2.61.0",
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.19.19",
    "@vitest/coverage-v8": "^4.1.7",
    "esbuild": "^0.28.0",
    "jsdom": "^26.1.0",
    "orval": "8.9.1",
    "svelte": "^5.55.9",
    "svelte-check": "^4.4.8",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "vite": "^6.4.2",
    "vitest": "^4.1.7"
  }
}
